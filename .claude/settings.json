{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/srv/monstruo_dev/.claude/hooks/rebuild-on-edit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/srv/monstruo_dev/.claude/hooks/pre-push-checks.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(docker compose *)",
      "Bash(docker exec monstruo-dev-*:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs monstruo-dev-*:*)",
      "Bash(curl -fsS http://127.0.0.1:90*:*)",
      "Bash(curl -s http://127.0.0.1:90*:*)",
      "Bash(curl -sI http://127.0.0.1:90*:*)"
    ]
  }
}
