# MONSTRUO - ejemplo base (referencia)
PORT=9000
DB_URL=postgresql://monstruo:monstruo@db:5432/monstruo
ENV_TYPE=prod

# Seguridad
SECRET_KEY=replace_with_a_long_random_secret
COOKIE_DOMAIN=.telconsulting.cl
COOKIE_SECURE=1

# Ticketera / Compliance
TICKET_AUTO_REPLY_ENABLED=false
TICKET_AUTO_REPLY_DELAY_MINUTES=15
TICKET_AUTO_REPLY_ALLOWLIST_EMAILS=
TICKET_AUTO_REPLY_ALLOWLIST_DOMAINS=
TICKET_AUTO_REPLY_REQUIRE_ALLOWLIST=true
TICKET_AUTO_REPLY_BLOCKED_LOCALPARTS=noreply,no-reply,mailer-daemon,postmaster
TICKET_ATTACHMENTS_DIR=/srv/monstruo/ticketera/data/tickets
COMPLIANCE_EXPORT_DIR=/srv/monstruo/ticketera/data/compliance
COMPLIANCE_TZ=America/Santiago
COMPLIANCE_EXPORT_HOUR=2
COMPLIANCE_PURGE_HOUR=2
COMPLIANCE_PURGE_GRACE_DAYS=30
JOBS_STALE_RUNNING_MINUTES=20
SYS_JOBS_RETENTION_DAYS=14
TKS_SLA_EVAL_LIMIT=500
TICKET_RETENTION_PUBLIC_DAYS=365
TICKET_RETENTION_INTERNAL_DAYS=1095
TICKET_RETENTION_RESTRICTED_DAYS=1825
CHANNELS_ENABLED=false
WHATSAPP_ADAPTER_MODE=disabled
THREECX_ADAPTER_MODE=disabled
WHATSAPP_BASE_URL=
WHATSAPP_AUTH_TOKEN=
WHATSAPP_TIMEOUT_SECONDS=10
THREECX_BASE_URL=
THREECX_AUTH_TOKEN=
THREECX_TIMEOUT_SECONDS=10
CHANNELS_MAX_ATTEMPTS=3
CHANNELS_RETRY_BASE_SECONDS=60
CHANNELS_RETRY_MAX_SECONDS=900
JIRA_BASE_URL=
JIRA_USER=
JIRA_API_TOKEN=
JIRA_PROJECT_KEYS=
JIRA_SYNC_ENABLED=false
JIRA_SYNC_DAILY_HOUR=3
JIRA_SYNC_TZ=America/Santiago

# Integraciones (Laudus / Parrotfy)
LAUDUS_BASE_URL=https://api.laudus.cl
LAUDUS_USERNAME=your_user
LAUDUS_PASSWORD=your_password
LAUDUS_COMPANY_VAT_ID=00000000-0
PARROTFY_BASE_URL=https://yourcompany.parrotfy.com
PARROTFY_TOKEN=your_token

# IA Centralization
RUTA_IA_RAIZ=/srv/inteligencia_artificial
RUTA_IA_MODELOS=/srv/inteligencia_artificial/modelos
RUTA_IA_PROMPTS=/srv/inteligencia_artificial/prompts
RUTA_IA_DATOS=/srv/inteligencia_artificial/datos
RUTA_IA_CACHE=/srv/inteligencia_artificial/cache
LOCAL_AI_BASE_URL=http://127.0.0.1:11434
AI_MODE=ollama_generate
AI_MODEL=tinyllama

# Otros
DEMO_MODE=0
SUDO_PASS=your_sudo_password
ULTRON_LLM_ENABLED=1
ULTRON_LLM_MODEL=qwen2.5-coder:7b

# Google OAuth (Nuevas)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
