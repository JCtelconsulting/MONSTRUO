{
  "version": "1.0",
  "root_allowed": [".env", ".gitignore", ".agent", ".git", "code", "data", "docs", "ops", "tests"],
  "rules": {
    "code/app": { "description": "Backend FastAPI", "allowed_extensions": [".py", ".md"] },
    "code/static": { "description": "Frontend Component-Based", "allowed_extensions": [".html", ".css", ".js", ".json", ".md"] },
    "code/procesos": { "description": "Scripts de Negocio", "allowed_extensions": [".py", ".sh", ".md"] },
    "ops": { "description": "Operaciones y Mantenimiento", "allowed_extensions": [".py", ".sh", ".service", ".timer", ".json", ".env", ".md"] },
    "docs": { "description": "Documentacion Oficial", "allowed_extensions": [".md", ".txt", ".yaml", ".json"] },
    "data": { "description": "Datos Persistentes", "allowed_extensions": [".db", ".log", ".sqlite", ".xlsx", ".csv", ".json", ".md"] },
    "tests": { "description": "Pruebas E2E y Hardening", "allowed_extensions": [".py", ".md", ".json"] }
  },
  "blocked_paths": [
    "data/**/*.py",
    "code/venv",
    "**/__pycache__",
    "**/*.bak",
    "**/*.old"
  ]
}
