# Configuración del Servidor
# ========================
# Entorno (development, production)
ENV=production
# Puerto interno del contenedor (no cambiar si usas docker-compose por defecto)
PORT=8000
# Usuario y Grupo del sistema (para permisos de archivos en Linux)
PUID=1000
PGID=1000

# Seguridad
# =========
# Clave maestra para firmar tokens JWT (CAMBIAR EN PRODUCCION)
TERRENEITOR_SECRET_KEY=cambiar_esta_clave_por_una_larga_y_segura
# Tiempo de expiración de tokens (minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Rutas de Datos (Volumenes Docker)
# ================================
# Mapeadas internamente en el contenedor
BASE_FILES_DIR=/app/data/files
TERRENEITOR_LOCKS_DIR=/app/data/locks
DB_DIR=/app/data/db
LOG_DIR=/app/data/logs
TERRENEITOR_REPORTES_DIR=/app/data/reportes

# Sincronización
# ==============
# Intervalo de escaneo de archivos (segundos)
TERRENEITOR_SYNC_INTERVAL=900

# Observabilidad (Sentry / GlitchTip)
# ===================================
# Dejar vacío para desactivar. Ejemplo: https://xxxx@sentry.io/12345
SENTRY_DSN=
