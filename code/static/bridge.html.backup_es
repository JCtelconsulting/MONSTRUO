<!doctype html>
<html lang="es">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Monstruo - Puente de Agentes</title>
  <link rel="stylesheet" href="css/style.css">
  <style>
    .msg-bubble {
      background: rgba(16, 20, 24, 0.6);
      border: 1px solid #2d3748;
      padding: 16px;
      margin-bottom: 12px;
      border-radius: 6px;
      transition: all 0.2s;
    }

    .msg-bubble:hover {
      border-color: #4a5568;
    }

    .msg-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
    }

    .msg-title {
      font-weight: 600;
      color: #e2e8f0;
    }

    .role-pill {
      font-size: 0.75rem;
      background: #2d3748;
      color: #a0aec0;
      padding: 2px 8px;
      border-radius: 99px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .proposal-card {
      border-left: 4px solid #ecc94b;
    }

    .proposal-actions {
      margin-top: 12px;
      display: flex;
      gap: 8px;
    }

    .status-badge {
      font-size: 0.7rem;
      font-weight: 700;
    }

    .status-pending {
      color: #ecc94b;
    }

    .status-approved {
      color: #48bb78;
    }

    .status-rejected {
      color: #f56565;
    }

    .payload-box {
      background: #1a202c;
      padding: 8px;
      border-radius: 4px;
      font-family: monospace;
      font-size: 0.8rem;
      color: #718096;
      max-height: 120px;
      overflow-y: auto;
      margin-top: 8px;
      border: 1px solid #2d3748;
    }
  </style>
</head>

<body>
  <div class="app">
    <aside class="sidebar">
      <div class="brand">
        <div class="brand-title">MONSTRUO</div>
        <div class="brand-sub">Puente de Agentes</div>
      </div>
      <nav class="nav">
        <a class="nav-item" href="/ui/home.html">Dashboard</a>
        <div class="nav-label">Puente</div>
        <a class="nav-item active" href="#">Mensajes</a>
      </nav>
      <div class="sidebar-foot">
        <button class="btn btn-ghost" onclick="location.href='/ui/'">Volver</button>
      </div>
    </aside>

    <main class="main">
      <header class="topbar">
        <div class="topbar-left">
          <h1 class="h1">Puente de Agentes</h1>
          <div class="muted">Comunicación y aprobación entre agentes.</div>
        </div>
      </header>

      <!-- PENDING APPROVALS -->
      <section class="grid grid-1">
        <div class="card" style="border-top: 2px solid #ecc94b">
          <div class="card-head">
            <div class="h2">Acciones Pendientes</div>
            <div class="muted">Propuestas que requieren tu aprobación</div>
          </div>
          <div class="card-body" id="pendingBox">
            <div class="muted">Cargando...</div>
          </div>
        </div>
      </section>

      <!-- INBOX / FEED -->
      <section class="grid grid-1">
        <div class="card">
          <div class="card-head">
            <div class="h2">Historial del Hilo</div>
            <div class="row" style="gap:8px;">
              <input class="input" id="currThread" value="jarvis" style="width:120px;" placeholder="Hilo ID" />
              <button class="btn btn-sm" onclick="loadFeed()">Actualizar</button>
            </div>
          </div>
          <div class="card-body" id="feedBox">
            <div class="muted">Cargando historial...</div>
          </div>
        </div>
      </section>

    </main>
  </div>

  <script>
    const API = location.origin;
    const $ = (id) => document.getElementById(id);
    function authHeaders() { return { "Authorization": "Bearer " + localStorage.getItem("token") }; }

    async function loadPending() {
      try {
        const r = await fetch(API + "/bridge/pending?thread_id=" + $("currThread").value, { headers: authHeaders() });
        if (!r.ok) { $("pendingBox").innerText = "Error de Auth"; return; }
        const d = await r.json();
        const box = $("pendingBox");
        box.innerHTML = "";
        if (d.items.length === 0) {
          box.innerHTML = "<div class='muted'>Sin propuestas pendientes.</div>";
          return;
        }
        d.items.forEach(m => {
          const div = document.createElement("div");
          div.className = "msg-bubble proposal-card";
          div.innerHTML = `
             <div class="msg-head">
               <span class="msg-title">${m.title || "Propuesta Sin Título"}</span>
               <span class="role-pill">De: ${m.from_agent}</span>
             </div>
             <p style="margin-bottom:8px; line-height:1.5;">${m.body}</p>
             
             ${m.payload_json && m.payload_json !== '{}' ? `<div class="payload-box">${m.payload_json}</div>` : ''}

             <div class="proposal-actions">
               <button class="btn btn-sm" onclick="decide(${m.id}, 'approve')">Aprobar</button>
               <button class="btn btn-sm btn-danger" onclick="decide(${m.id}, 'reject')">Rechazar</button>
             </div>
           `;
          box.appendChild(div);
        });
      } catch (e) { $("pendingBox").innerText = String(e); }
    }

    async function loadFeed() {
      try {
        const t = $("currThread").value;
        const r = await fetch(API + "/bridge/inbox?limit=20&thread_id=" + t, { headers: authHeaders() });
        if (!r.ok) { $("feedBox").innerText = "Error de Auth"; return; }
        const d = await r.json();
        const box = $("feedBox");
        box.innerHTML = "";
        if (d.items.length === 0) {
          box.innerHTML = "<div class='muted'>No hay mensajes en este hilo.</div>";
          return;
        }
        // Sort desc for feed
        const items = d.items.sort((a, b) => b.id - a.id);
        items.forEach(m => {
          const div = document.createElement("div");
          div.className = "msg-bubble";

          if (m.requires_approval) div.classList.add("proposal-card");

          let statusHtml = "";
          if (m.approval_status === "approved") statusHtml = `<span class="status-badge status-approved">APROBADO</span>`;
          else if (m.approval_status === "rejected") statusHtml = `<span class="status-badge status-rejected">RECHAZADO</span>`;
          else if (m.approval_status === "pending") statusHtml = `<span class="status-badge status-pending">PENDIENTE</span>`;

          div.innerHTML = `
             <div class="msg-head">
                <div style="display:flex; gap:8px; align-items:center">
                    <span class="role-pill">${m.from_agent} &rarr; ${m.to_agent}</span>
                    <span style="font-size:0.8rem; font-weight:600">${m.title}</span>
                </div>
                <div style="text-align:right">
                    ${statusHtml}
                    <div class="muted" style="font-size:0.6rem; margin-top:2px;">${m.created_at.substring(11, 16)}</div>
                </div>
             </div>
             <div style="color:#cbd5e0; font-size:0.95rem;">${m.body}</div>
           `;
          box.appendChild(div);
        });
        loadPending();
      } catch (e) { }
    }

    async function decide(id, action) {
      if (!confirm(`¿Estás seguro de ${action === 'approve' ? 'APROBAR' : 'RECHAZAR'} esta propuesta?`)) return;
      const r = await fetch(API + `/bridge/${id}/${action}`, { method: "POST", headers: authHeaders() });
      if (r.ok) loadFeed();
      else alert("Error " + r.status);
    }

    loadFeed();
    // Auto refresh every 10s
    setInterval(loadFeed, 10000);
  </script>
</body>

</html>