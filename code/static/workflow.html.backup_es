<!doctype html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Monstruo | Workflow</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- Monstruo Styles -->
    <link rel="stylesheet" href="css/style.css">
</head>

<body>

    <!-- Sidebar -->
    <header>
        <h1>Monstruo</h1>
        <nav>
            <a href="/ui/" class="nav-link"><i class="fas fa-home"></i> Dashboard</a>
            <a href="/ui/workflow.html" class="nav-link active"><i class="fas fa-tasks"></i> Workflow</a>
        </nav>
        <div style="flex:1"></div>
        <div class="muted" style="text-align:center; font-size:0.75rem;">v1.0.2</div>
    </header>

    <!-- Main Content -->
    <main>
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px;">
            <div>
                <h2 style="font-size:1.8rem; margin:0;">Workflow</h2>
                <span class="muted" style="margin:0;">Gestión de Casos y Discrepancias</span>
            </div>
            <button class="btn btn-primary" onclick="loadCases()"><i class="fas fa-sync"></i> Refrescar</button>
        </div>

        <!-- Create + List Row -->
        <div class="row">
            <!-- Create Case Card -->
            <div class="card" style="flex:1; min-width:300px;">
                <h3><i class="fas fa-plus-circle"></i> Nuevo Caso</h3>
                <label>Titulo</label>
                <input id="case_title" placeholder="Ej: Auditoría Facturas Enero" />

                <label>Descripcion</label>
                <textarea id="case_desc" placeholder="Contexto..."></textarea>

                <div class="row" style="margin-bottom:0;">
                    <div style="flex:1">
                        <label>Rol</label>
                        <select id="case_owner">
                            <option value="ops">Ops</option>
                            <option value="finance">Finance</option>
                            <option value="warehouse">Warehouse</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>
                    <div style="flex:1">
                        <label>Prioridad</label>
                        <select id="case_priority">
                            <option value="low">Low</option>
                            <option value="medium" selected>Medium</option>
                            <option value="high">High</option>
                            <option value="critical">Critical</option>
                        </select>
                    </div>
                </div>

                <div style="text-align:right; margin-top:20px;">
                    <button class="btn btn-primary" onclick="createCase()">Crear Caso</button>
                </div>
                <div id="create_case_msg" class="muted" style="margin-top:10px; color:var(--neon);"></div>
            </div>

            <!-- Case List Card -->
            <div class="card" style="flex:2; min-width:400px;">
                <h3><i class="fas fa-folder-open"></i> Casos Activos</h3>
                <div id="cases_box">
                    <div class="muted">Cargando...</div>
                </div>
            </div>
        </div>

        <!-- Detail View -->
        <div class="card" style="min-height:300px;">
            <h3><i class="fas fa-eye"></i> Detalle del Caso</h3>
            <div id="case_detail_meta" class="muted">Selecciona un caso arriba para ver sus tareas.</div>
            <hr style="border:0; border-top:1px solid var(--border); margin:15px 0;">
            <div id="case_detail_box"></div>
        </div>
    </main>

    <script>
        function getToken() {
            return localStorage.getItem("monstruo_token") || localStorage.getItem("token") || "";
        }

        async function api(path, opts = {}) {
            const token = getToken();
            const headers = opts.headers || {};
            headers["Content-Type"] = "application/json";
            if (token) headers["Authorization"] = "Bearer " + token;
            const res = await fetch(path, { ...opts, headers });
            let txt = await res.text();
            let js = null;
            try { js = JSON.parse(txt); } catch (e) { }
            return { status: res.status, json: js, text: txt };
        }

        function esc(s) { return (s || "").toString().replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;"); }

        function getStatusPill(s) {
            return `<span class="pill status-${s}">${esc(s)}</span>`;
        }

        async function loadCases() {
            const box = document.getElementById("cases_box");
            box.innerHTML = '<div class="muted">Cargando...</div>';
            const r = await api("/workflow/cases");

            if (r.status === 401) {
                box.innerHTML = "<span style='color:var(--danger)'>Sesión expirada. <a href='/ui/' style='color:var(--neon)'>Login</a></span>";
                return;
            }
            if (r.status !== 200) {
                box.innerHTML = "<span style='color:var(--danger)'>Error: " + esc(r.text) + "</span>";
                return;
            }

            const items = (r.json && r.json.items) ? r.json.items : [];
            if (!items.length) {
                box.innerHTML = "<div class='muted'>No hay casos registrados.</div>";
                return;
            }

            let html = "<table><thead><tr><th>ID</th><th>Titulo</th><th>Status</th><th>Owner</th><th></th></tr></thead><tbody>";
            for (const c of items) {
                html += `<tr>
      <td>${esc(c.id)}</td>
      <td><b style="color:#fff">${esc(c.title)}</b><br><span style="font-size:0.75rem; color:var(--text-soft)">${esc(c.priority)}</span></td>
      <td>${getStatusPill(c.status)}</td>
      <td>${esc(c.owner_role)}</td>
      <td style="text-align:right">
        <button class="btn" style="padding:4px 10px;" onclick="openCase(${c.id})">Ver</button>
      </td>
    </tr>`;
            }
            html += "</tbody></table>";
            box.innerHTML = html;
        }

        async function createCase() {
            const msg = document.getElementById("create_case_msg");
            msg.textContent = "";

            const title = document.getElementById("case_title").value.trim();
            const description = document.getElementById("case_desc").value.trim();
            const owner_role = document.getElementById("case_owner").value;
            const priority = document.getElementById("case_priority").value;

            if (!title) { msg.textContent = "Falta el titulo."; return; }

            const r = await api("/workflow/cases", {
                method: "POST",
                body: JSON.stringify({ title, description, owner_role, priority })
            });

            if (r.status !== 200) {
                msg.innerHTML = "<span style='color:var(--danger)'>Error: " + esc(r.text) + "</span>";
                return;
            }

            msg.textContent = "Caso #" + (r.json.case_id || "?") + " creado.";
            document.getElementById("case_title").value = "";
            document.getElementById("case_desc").value = "";
            await loadCases();
        }

        async function openCase(caseId) {
            const meta = document.getElementById("case_detail_meta");
            const box = document.getElementById("case_detail_box");

            meta.innerHTML = "Cargando caso...";
            box.innerHTML = "";

            const r = await api("/workflow/cases/" + caseId);
            if (r.status !== 200) {
                meta.innerHTML = "<span style='color:var(--danger)'>Error: " + esc(r.text) + "</span>";
                return;
            }

            const c = r.json.case || {};
            const tasks = r.json.tasks || [];
            const links = r.json.links || [];

            meta.innerHTML = `<span style="font-size:1.2rem; color:var(--neon)">${esc(c.title)}</span> &bull; <span class="pill status-${c.status}">${esc(c.status)}</span>`;

            let html = `<div class="row">`;

            // Tasks Column
            html += `<div style="flex:2; min-width:300px;">`;
            html += `<h4 style="color:#fff; border-bottom:1px solid var(--border); padding-bottom:10px;">PROGRESO (${tasks.length} Tareas)</h4>`;

            if (!tasks.length) {
                html += `<div class="muted">No hay tareas asociadas. Agrega una arriba.</div>`;
            } else {
                html += `<table><thead><tr><th>ID</th><th>Tarea</th><th>Estado</th><th>Acción</th></tr></thead><tbody>`;
                for (const t of tasks) {
                    const opts = ["open", "doing", "blocked", "done"];
                    let optionsHtml = "";
                    for (const o of opts) {
                        optionsHtml += `<option value="${o}" ${o === t.status ? "selected" : ""}>${o.toUpperCase()}</option>`;
                    }

                    html += `<tr>
        <td>${esc(t.id)}</td>
        <td>
          <div style="font-weight:600">${esc(t.title)}</div>
          <div style="font-size:0.8rem; color:var(--text-soft)">${esc(t.description || "")}</div>
          <div style="margin-top:4px;">
             <input id="cmt_${t.id}" placeholder="Comentar..." style="padding:4px; font-size:0.8rem; width:150px; display:inline-block;" />
             <button class="btn" style="padding:4px 8px; font-size:0.7rem" onclick="addComment(${t.id})"><i class="fas fa-comment"></i></button>
          </div>
        </td>
        <td>${getStatusPill(t.status)}</td>
        <td>
          <select style="padding:4px; font-size:0.8rem; width:auto;" onchange="setTaskStatus(${t.id}, this.value)">
            ${optionsHtml}
          </select>
        </td>
      </tr>`;
                }
                html += `</tbody></table>`;
            }
            html += `</div>`;

            // Links Column
            html += `<div style="flex:1; min-width:200px; background:rgba(0,0,0,0.2); padding:15px; border-radius:12px;">`;
            html += `<h4 style="color:#fff; margin-top:0;">LINKS EVIDENCIA</h4>`;
            if (!links.length) {
                html += `<div class="muted">Sin evidencia linkeada.</div>`;
            } else {
                html += `<ul style="list-style:none; padding:0;">`;
                for (const l of links) {
                    html += `<li style="margin-bottom:8px; padding:8px; background:rgba(255,255,255,0.05); border-radius:6px;">
        <i class="fas fa-link" style="color:var(--neon)"></i> 
        <span style="font-size:0.85rem; color:#fff">${esc(l.link_key)}</span>
        <br><span style="font-size:0.7rem; color:var(--text-soft)">${esc(l.link_type)}</span>
      </li>`;
                }
                html += `</ul>`;
            }
            html += `</div>`; // end right col

            html += `</div>`; // end row
            box.innerHTML = html;
        }

        async function setTaskStatus(taskId, status) {
            const r = await api("/workflow/tasks/" + taskId + "/status", {
                method: "POST",
                body: JSON.stringify({ status })
            });
            if (r.status !== 200) {
                alert("Error actualizando estado: " + r.text);
                return;
            }
            // Optional: reload case to refresh pills, but selecting changes visual
        }

        async function addComment(taskId) {
            const inp = document.getElementById("cmt_" + taskId);
            const comment = (inp.value || "").trim();
            if (!comment) return;
            const r = await api("/workflow/tasks/" + taskId + "/comment", {
                method: "POST",
                body: JSON.stringify({ comment })
            });
            if (r.status !== 200) {
                alert("Error comentando: " + r.text);
                return;
            }
            inp.value = "";
            alert("Comentario agregado.");
        }

        (async function init() {
            await loadCases();
        })();
    </script>
</body>

</html>