FROM python:3.12-slim

WORKDIR /app

# System deps
RUN apt-get update && apt-get install -y libpq-dev gcc curl iputils-ping && rm -rf /var/lib/apt/lists/*

# Python deps
COPY code/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy Code (matches dev volume mount path)
COPY code /app/code

# Set python path so 'app' module is found
ENV PYTHONPATH=/app/code

# Default command
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "9000"]
