# MONSTRUO - ejemplo base (referencia)
PORT=9000
DB_URL=postgresql://monstruo:monstruo@db:5432/monstruo
ENV_TYPE=prod

# Seguridad
SECRET_KEY=replace_with_a_long_random_secret
COOKIE_DOMAIN=.telconsulting.cl
COOKIE_SECURE=1

# Ticketera / Compliance
TICKET_AUTO_REPLY_ENABLED=false
TICKET_AUTO_REPLY_DELAY_MINUTES=15
TICKET_AUTO_REPLY_ALLOWLIST_EMAILS=
TICKET_AUTO_REPLY_ALLOWLIST_DOMAINS=
TICKET_AUTO_REPLY_REQUIRE_ALLOWLIST=true
TICKET_AUTO_REPLY_BLOCKED_LOCALPARTS=noreply,no-reply,mailer-daemon,postmaster
TICKET_ATTACHMENTS_DIR=/srv/monstruo/data/tickets
COMPLIANCE_EXPORT_DIR=/srv/monstruo/data/compliance
COMPLIANCE_TZ=America/Santiago
COMPLIANCE_EXPORT_HOUR=2
COMPLIANCE_PURGE_HOUR=2
COMPLIANCE_PURGE_GRACE_DAYS=30
JOBS_STALE_RUNNING_MINUTES=20
SYS_JOBS_RETENTION_DAYS=14
TKS_SLA_EVAL_LIMIT=500
TICKET_RETENTION_PUBLIC_DAYS=365
TICKET_RETENTION_INTERNAL_DAYS=1095
TICKET_RETENTION_RESTRICTED_DAYS=1825
CHANNELS_ENABLED=false
WHATSAPP_ADAPTER_MODE=disabled
THREECX_ADAPTER_MODE=disabled
WHATSAPP_BASE_URL=
WHATSAPP_AUTH_TOKEN=
WHATSAPP_TIMEOUT_SECONDS=10
THREECX_BASE_URL=
THREECX_AUTH_TOKEN=
THREECX_TIMEOUT_SECONDS=10
CHANNELS_MAX_ATTEMPTS=3
CHANNELS_RETRY_BASE_SECONDS=60
CHANNELS_RETRY_MAX_SECONDS=900
JIRA_BASE_URL=
JIRA_USER=
JIRA_API_TOKEN=
JIRA_PROJECT_KEYS=
JIRA_SYNC_ENABLED=false
JIRA_SYNC_DAILY_HOUR=3
JIRA_SYNC_TZ=America/Santiago
