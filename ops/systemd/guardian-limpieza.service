[Unit]
Description=MONSTRUO Guardian - Limpieza de backups (oneshot)
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/srv/monstruo_dev
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 /srv/monstruo_dev/ops/guardian/scripts/saneador_nombres_prohibidos.py --config /srv/monstruo_dev/ops/guardian/config/configuracion_guardian.json --db /srv/monstruo_dev/ops/guardian/guardian.sqlite --salida /srv/monstruo_dev/ops/guardian/reportes/reporte_nombres_prohibidos__latest.json
