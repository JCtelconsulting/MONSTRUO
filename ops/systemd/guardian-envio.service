[Unit]
Description=MONSTRUO Guardian - Envio a IA local (oneshot)
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/srv/monstruo
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/srv/monstruo_dev/ops/guardian/entorno_guardian.env
ExecStart=/srv/monstruo_dev/venv/bin/python /srv/monstruo_dev/ops/guardian/enviar_a_ia_local.py --config /srv/monstruo_dev/ops/guardian/configuracion_guardian.json --once --limite 10 --timeout 3
