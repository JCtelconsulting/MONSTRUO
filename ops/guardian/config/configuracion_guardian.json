{
  "auto_mover_prohibidos": false,
  "deduplicacion_segundos": 120,
  "excluir_subrutas": [
    "backups",
    "venv",
    ".git",
    "__pycache__"
  ],
  "limpiador_backups": {
    "borrar_carpetas_vacias_mayores_a_dias": 30,
    "max_por_item": 5
  },
  "proyecto_raiz": "/srv/monstruo_dev",
  "rutas": {
    "bd_eventos": "/srv/monstruo_dev/ops/guardian/guardian.sqlite",
    "carpeta_backups": "/srv/monstruo_dev/backups",
    "docs_contexto": "/srv/monstruo_dev/docs/PROYECTO_CONTEXTO.md",
    "raiz_proyecto": "/srv/monstruo_dev"
  },
  "severidades": {
    "critical": "CRITICAL",
    "info": "INFO",
    "warn": "WARN"
  },
  "sufijos_prohibidos": [
    ".bak",
    ".old",
    "_backup",
    "_final",
    "_v2",
    "v1",
    "v2"
  ],
  "vigilante_archivos": {
    "excluir_subrutas": [
      "backups",
      "venv",
      ".git",
      "__pycache__"
    ],
    "extensiones_interes": [
      ".py",
      ".js",
      ".html",
      ".css",
      ".md",
      ".sql"
    ],
    "incluir": [
      "/srv/monstruo_dev"
    ],
    "patrones_prohibidos": [
      ".bak",
      ".old",
      "_backup",
      "_final",
      "_v2",
      "v1",
      "v2"
    ]
  },
  "vigilante_logs": {
    "modo": "journalctl",
    "patrones_error": [
      "Traceback",
      "ERROR",
      "Exception",
      "OperationalError",
      "IntegrityError"
    ],
    "unidad_systemd": "monstruo-backend"
  },
  "vigilante_registros": {
    "modo": "journalctl",
    "patrones_error": [
      "Traceback",
      "ERROR",
      "Exception",
      "OperationalError",
      "IntegrityError"
    ],
    "unidad_systemd": "monstruo-backend"
  }
}
