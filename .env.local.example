# MONSTRUO - ejemplo local DEV
PORT=9001
DB_URL=postgresql://monstruo:monstruo@db:5432/monstruo
ENV_TYPE=dev

# Seguridad local
SECRET_KEY=replace_with_a_long_random_secret_for_dev
COOKIE_DOMAIN=.telconsulting.cl
COOKIE_SECURE=1

# Ticketera / Compliance
TICKET_AUTO_REPLY_ENABLED=false
COMPLIANCE_EXPORT_DIR=/srv/monstruo_dev/data/compliance
COMPLIANCE_TZ=America/Santiago
COMPLIANCE_EXPORT_HOUR=2
COMPLIANCE_PURGE_HOUR=2
COMPLIANCE_PURGE_GRACE_DAYS=30
TICKET_RETENTION_PUBLIC_DAYS=365
TICKET_RETENTION_INTERNAL_DAYS=1095
TICKET_RETENTION_RESTRICTED_DAYS=1825
